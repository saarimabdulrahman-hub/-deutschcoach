# Database — defaults to an absolute-path SQLite file in backend/.
# Override for MySQL:  mysql+pymysql://root:rootpassword@localhost:3306/deutschcoach
# DATABASE_URL=sqlite:///C:/Users/saari/projects/german-tutor-chatbot/backend/deutschcoach.db
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
CORS_ORIGIN=http://localhost:3000
ANTHROPIC_API_KEY=sk-ant-...  # Optional — leave empty to disable chat
ANTHROPIC_BASE_URL=https://api.anthropic.com  # Override for compatible APIs (e.g. DeepSeek)
ANTHROPIC_MODEL=claude-sonnet-4-6  # Model name for the /v1/messages endpoint

# Email (SMTP) — optional for password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@deutschcoach.app
FRONTEND_URL=http://localhost:3456
